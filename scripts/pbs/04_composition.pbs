#!/bin/bash
#PBS -N venet_composition
#PBS -l select=1:ncpus=2:mem=16gb
#PBS -l walltime=01:00:00
#PBS -j oe
#PBS -o /srv/scratch/z5530616/projects/venetoclax_aml_immune/logs/composition.log
#PBS -M alextatu2014@gmail.com
#PBS -m abe

set -euo pipefail

PROJECT=/srv/scratch/z5530616/projects/venetoclax_aml_immune
CONDA_ENV=/srv/scratch/z5530616/projects/pediatric_aml_relapse_multiome/envs/sc_multiome
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
LOG=${PROJECT}/logs/composition_${TIMESTAMP}.log

source /srv/scratch/z5530616/miniconda3/etc/profile.d/conda.sh
conda activate "${CONDA_ENV}"

echo "Start: $(date)" | tee "${LOG}"

PYTHONNOUSERSITE=1 python3 "${PROJECT}/scripts/composition/04_composition.py" "${PROJECT}" \
    2>&1 | tee -a "${LOG}"

echo "End: $(date)" | tee -a "${LOG}"
