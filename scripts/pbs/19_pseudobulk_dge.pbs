#!/bin/bash
#PBS -N venet_pseudobulk
#PBS -l select=1:ncpus=8:mem=128gb
#PBS -l walltime=02:00:00
#PBS -j oe
#PBS -o /srv/scratch/z5530616/projects/venetoclax_aml_immune/logs/pseudobulk_dge.log
#PBS -M alextatu2014@gmail.com
#PBS -m abe

set -euo pipefail

PROJECT=/srv/scratch/z5530616/projects/venetoclax_aml_immune
CONDA_ENV=/srv/scratch/z5530616/projects/pediatric_aml_relapse_multiome/envs/sc_multiome
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
LOG=${PROJECT}/logs/pseudobulk_dge_${TIMESTAMP}.log

mkdir -p "${PROJECT}/results/figures/validation" \
         "${PROJECT}/results/tables/validation" \
         "${PROJECT}/logs"

source /srv/scratch/z5530616/miniconda3/etc/profile.d/conda.sh
conda activate "${CONDA_ENV}"

echo "Start: $(date)" | tee "${LOG}"
PYTHONNOUSERSITE=1 python3 "${PROJECT}/scripts/validation/19_pseudobulk_dge.py" \
    "${PROJECT}" 2>&1 | tee -a "${LOG}"
echo "End: $(date)" | tee -a "${LOG}"
